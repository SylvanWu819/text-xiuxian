# 自动检测文本文件并规范化行尾符
* text=auto

# 源代码
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# 样式文件
*.css text eol=lf
*.scss text eol=lf

# HTML
*.html text eol=lf

# 配置文件
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# Shell 脚本
*.sh text eol=lf
*.bash text eol=lf

# Windows 脚本
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.vsix binary
